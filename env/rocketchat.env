# ============================================================
# Configuration Rocket.Chat - Debian 13 + Docker Compose
# ============================================================

# Dossier d'installation final sur le serveur Debian
INSTALL_DIR="/opt/rocketchat"

# Adresse utilisée dans le navigateur pour accéder à Rocket.Chat.
# Remplace ADRESSE_IP_DU_SERVEUR par l'adresse IP réelle de ta Debian.
# Pour connaître l'adresse IP sur une machine vierge :
# hostname -I
#
# Exemple :
# ROOT_URL="http://192.168.42.139:3000"
ROOT_URL="http://ADRESSE_IP_DU_SERVEUR:3000"

# Port exposé sur le serveur Debian
ROCKETCHAT_PORT="3000"

# Images Docker
MONGO_IMAGE="mongo:7.0"
ROCKETCHAT_IMAGE="registry.rocket.chat/rocketchat/rocket.chat:latest"

# Nom des conteneurs
MONGO_CONTAINER_NAME="rocketchat-mongodb"
MONGO_INIT_CONTAINER_NAME="rocketchat-mongodb-init"
ROCKETCHAT_CONTAINER_NAME="rocketchat"

# MongoDB
MONGO_DB_NAME="rocketchat"
MONGO_REPLICA_SET="rs0"
MONGO_OPLOG_SIZE="128"

# Compte administrateur Rocket.Chat
# Ces variables sont prises en compte surtout au premier démarrage avec une base MongoDB neuve.
ADMIN_USERNAME="admin"
ADMIN_NAME="Administrateur Rocket.Chat"
ADMIN_EMAIL="admin@example.local"
ADMIN_PASS="CHANGE_ME_ROCKETCHAT_ADMIN_PASSWORD"

# Assistant de configuration Rocket.Chat
SKIP_SETUP_WIZARD="true"

# Droits Docker
ADD_USER_TO_DOCKER_GROUP="true"
