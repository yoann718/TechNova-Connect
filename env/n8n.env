# Configuration n8n TechNova

INSTALL_DIR="/opt/n8n"

N8N_HOST="n8n.technova.local"
N8N_PORT="5678"
N8N_PROTOCOL="http"

POSTGRES_DB="n8n"
POSTGRES_USER="n8n"
POSTGRES_PASSWORD="CHANGE_ME_N8N_DB_PASSWORD"

N8N_ENCRYPTION_KEY="CHANGE_ME_32_CHARACTERS_MINIMUM_KEY"

N8N_IMAGE="n8nio/n8n:latest"
POSTGRES_IMAGE="postgres:16-alpine"

ADD_USER_TO_DOCKER_GROUP="true"
